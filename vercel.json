{
  "version": 2,
  "builds": [
    {
      "src": "movie-api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "movie-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/movie-api/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/movie-frontend/index.html"
    }
  ]
}